{
  "name": "tera-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "compile": "hardhat --config hardhat.config.cjs compile",
    "test": "hardhat --config hardhat.config.cjs test",
    "deploy:local": "hardhat --config hardhat.config.cjs run scripts/deploy.cjs --network local",
    "deploy:fuji": "hardhat --config hardhat.config.cjs run scripts/deploy.cjs --network fuji",
    "deploy:mainnet": "hardhat --config hardhat.config.cjs run scripts/deploy.cjs --network avalanche"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^17.4.2",
    "hardhat": "^2.19.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "ethers": "^6.16.0"
  }
}
